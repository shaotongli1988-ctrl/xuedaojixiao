        "responses": {
          "200": {
            "description": "更新录用状态结果",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse_HiringRecord"
                }
              }
            }
          }
        }
      }
    }
