{
  "openapi": "3.0.3",
  "info": {
    "title": "Theme 18 Hiring Contract Snapshot",
    "version": "0.1.0",
    "description": "Frozen contract evidence for theme 18 hiring APIs."
  },
  "tags": [
    {
      "name": "performance.hiring",
      "description": "Theme 18 hiring management APIs."
    }
  ],
  "paths": {
    "/admin/performance/hiring/add": {
      "post": {
        "tags": [
          "performance.hiring"
        ],
        "summary": "新增录用",
        "operationId": "performanceHiringAdd",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/HiringSaveRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "新增录用结果",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse_HiringRecord"
                }
              }
            }
          }
        }
      }
    },
    "/admin/performance/hiring/close": {
      "post": {
        "tags": [
          "performance.hiring"
        ],
        "summary": "关闭录用",
        "operationId": "performanceHiringClose",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/HiringCloseRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "关闭录用结果",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse_HiringRecord"
                }
              }
            }
          }
        }
      }
    },
    "/admin/performance/hiring/info": {
      "get": {
        "tags": [
          "performance.hiring"
        ],
        "summary": "录用详情",
        "operationId": "performanceHiringInfo",
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "录用详情结果",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse_HiringRecord"
                }
              }
            }
          }
        }
      }
    },
    "/admin/performance/hiring/page": {
      "post": {
        "tags": [
          "performance.hiring"
        ],
        "summary": "录用分页",
        "operationId": "performanceHiringPage",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/HiringPageQuery"
              }
            }
          }
