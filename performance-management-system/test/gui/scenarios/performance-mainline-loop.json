  "scenarios": [
    {
      "name": "hr-performance-loop",
      "username": "hr_admin",
      "route": "/performance/initiated",
      "waitAfterNavigateMs": 3000,
      "steps": [
        {
          "type": "waitBodyText",
          "includes": [
            "已发起考核",
            "发起评估"
          ],
          "timeoutMs": 12000
        },
        {
          "type": "screenshot",
          "file": "performance-loop-hr-initiated.png"
        },
        {
          "type": "navigate",
          "route": "/performance/goals",
          "waitAfterMs": 1800
        },
        {
          "type": "waitBodyText",
          "includes": [
            "目标地图",
            "新建目标"
          ],
          "timeoutMs": 12000
        },
        {
          "type": "screenshot",
          "file": "performance-loop-hr-goals.png"
        },
        {
          "type": "navigate",
          "route": "/performance/feedback",
          "waitAfterMs": 1800
        },
        {
          "type": "waitBodyText",
          "includes": [
            "360 环评任务",
            "发起环评任务"
          ],
          "timeoutMs": 12000
        },
        {
          "type": "screenshot",
          "file": "performance-loop-hr-feedback.png"
        }
      ]
    },
    {
      "name": "manager-performance-loop",
      "username": "manager_rd",
      "route": "/performance/pending",
      "waitAfterNavigateMs": 3000,
      "steps": [
        {
          "type": "waitBodyText",
          "includes": [
            "待我审批"
          ],
          "timeoutMs": 12000
        },
        {
          "type": "assertVisibleText",
          "includes": [
            "待我审批"
          ],
          "excludes": [
            "发起评估"
          ]
        },
        {
          "type": "screenshot",
          "file": "performance-loop-manager-pending.png"
        },
        {
          "type": "navigate",
          "route": "/performance/goals",
          "waitAfterMs": 1800
        },
        {
          "type": "waitBodyText",
          "includes": [
            "目标地图"
          ],
          "timeoutMs": 12000
        },
        {
          "type": "screenshot",
          "file": "performance-loop-manager-goals.png"
        }
      ]
    },
    {
      "name": "employee-performance-loop",
      "username": "employee_platform",
      "route": "/performance/my-assessment",
      "waitAfterNavigateMs": 3000,
      "steps": [
        {
          "type": "waitBodyText",
          "includes": [
            "我的考核"
