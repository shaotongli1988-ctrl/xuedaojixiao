        {
          "type": "screenshot",
          "file": "performance-loop-employee-assessment.png"
        },
        {
          "type": "navigate",
          "route": "/performance/goals",
          "waitAfterMs": 1800
        },
        {
          "type": "waitBodyText",
          "includes": [
            "目标地图"
          ],
          "timeoutMs": 12000
        },
        {
          "type": "screenshot",
          "file": "performance-loop-employee-goals.png"
        },
        {
          "type": "navigate",
          "route": "/performance/pending",
          "waitAfterMs": 1800
        },
        {
          "type": "assertBodyText",
          "includes": [
            "404",
            "找不到您要查找的页面"
