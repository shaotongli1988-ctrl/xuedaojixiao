{
  "meta": {
    "name": "performance-mainline-loop-gui",
    "description": "绩效闭环最小 GUI 点测"
  },
  "defaults": {
    "uiBaseUrl": "http://127.0.0.1:9007",
    "apiBaseUrl": "http://127.0.0.1:8006",
    "chromeDebugUrl": "http://127.0.0.1:9222",
    "outputDir": "/Users/shaotongli/Documents/xuedao/performance-management-system/tasks/artifacts/performance-mainline-loop",
    "password": "123456",
    "viewport": {
      "width": 1440,
      "height": 1100,
