        {
          "type": "assertVisibleText",
          "includes": [
            "新建录用",
            "接受",
            "拒绝",
            "关闭"
          ]
        },
        {
          "type": "screenshot",
          "file": "theme18-hiring-hr-list.png"
        },
        {
          "type": "clickText",
          "text": "详情",
          "index": 0,
          "waitAfterMs": 1200
        },
        {
          "type": "waitBodyText",
          "includes": [
            "录用详情",
            "录用决策",
            "来源状态快照"
          ],
          "timeoutMs": 10000
        },
        {
          "type": "screenshot",
          "file": "theme18-hiring-hr-detail.png"
        }
      ]
    },
    {
      "name": "manager-hiring-scope",
      "username": "manager_rd",
      "route": "/performance/hiring",
      "waitAfterNavigateMs": 3000,
      "steps": [
        {
          "type": "waitBodyText",
          "includes": [
            "录用管理",
            "联调-主题18平台录用"
          ],
          "timeoutMs": 12000
        },
        {
          "type": "assertBodyText",
          "includes": [
            "联调-主题18平台录用"
          ],
          "excludes": [
            "联调-主题18销售录用"
          ]
