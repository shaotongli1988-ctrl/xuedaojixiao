        {
          "type": "screenshot",
          "file": "theme18-hiring-manager-scope.png"
        },
        {
          "type": "clickText",
          "text": "详情",
          "index": 0,
          "waitAfterMs": 1200
        },
        {
          "type": "waitBodyText",
          "includes": [
            "录用详情",
