        {
          "type": "screenshot",
          "file": "theme23-goal-plan-manager-assign-dialog.png"
        },
        {
          "type": "navigate",
          "route": "/performance/goals",
          "waitAfterMs": 1600
        },
        {
          "type": "waitBodyText",
          "includes": [
            "目标&计划总览",
            "生成日报"
          ],
          "timeoutMs": 12000
        },
        {
          "type": "clickText",
          "text": "生成日报",
          "waitAfterMs": 1200
        },
        {
          "type": "waitBodyText",
          "includes": [
            "日报汇报区",
            "日报摘要",
            "完成率榜 Top5",
