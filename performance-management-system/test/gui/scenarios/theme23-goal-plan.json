            "目标&计划总览",
            "今日运营区",
            "目标对比区",
            "目标配置区",
            "日报汇报区",
            "下发公共目标",
            "生成日报"
          ]
        },
        {
          "type": "screenshot",
          "file": "theme23-goal-plan-manager-overview.png"
        },
        {
          "type": "clickText",
          "text": "下发公共目标",
          "waitAfterMs": 1200
        },
        {
          "type": "waitBodyText",
